---
// เรดาร์ชาร์ตแบบ SVG ล้วน (ไม่พึ่ง JS) สำหรับแสดงคะแนนเฉลี่ยรายเกณฑ์
// values: อาร์เรย์ค่า 0-7 ความยาวเท่ากับ labels
interface Props {
  labels: string[];
  values: number[];
  max?: number;
}
const { labels, values, max = 7 } = Astro.props;
const n = labels.length;
const cx = 160;
const cy = 160;
const R = 120;

// มุมเริ่มที่ด้านบน (-90°) เรียงตามเข็มนาฬิกา
const angle = (i: number) => (Math.PI * 2 * i) / n - Math.PI / 2;
const point = (i: number, r: number) => {
  const a = angle(i);
  return [cx + r * Math.cos(a), cy + r * Math.sin(a)] as const;
};

// วงกริดหลายชั้น
const rings = [0.25, 0.5, 0.75, 1];
const axisPts = labels.map((_, i) => point(i, R));
const dataPts = values.map((v, i) => point(i, (Math.max(0, Math.min(max, v)) / max) * R));
const dataPath = dataPts.map((p) => p.join(",")).join(" ");
const labelPts = labels.map((_, i) => point(i, R + 22));
---
<svg viewBox="0 0 320 320" class="mx-auto h-auto w-full max-w-sm" role="img">
  <!-- วงกริด -->
  {rings.map((rf) => (
    <polygon
      points={labels.map((_, i) => point(i, R * rf).join(",")).join(" ")}
      fill="none"
      stroke="#e2e8f0"
      stroke-width="1"
    />
  ))}
  <!-- แกน -->
  {axisPts.map((p) => (
    <line x1={cx} y1={cy} x2={p[0]} y2={p[1]} stroke="#e2e8f0" stroke-width="1" />
  ))}
  <!-- พื้นที่ข้อมูล -->
  <polygon points={dataPath} fill="rgba(37,99,235,0.18)" stroke="#2563eb" stroke-width="2" />
  {dataPts.map((p) => <circle cx={p[0]} cy={p[1]} r="3" fill="#2563eb" />)}
  <!-- ป้ายเกณฑ์ -->
  {labelPts.map((p, i) => (
    <text
      x={p[0]}
      y={p[1]}
      font-size="11"
      font-weight="600"
      fill="#475569"
      text-anchor="middle"
      dominant-baseline="middle"
    >
      {labels[i]}
    </text>
  ))}
</svg>

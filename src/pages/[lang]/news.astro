---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, pick } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const news = (await getCollection("news")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const fmt = (d: Date) =>
  d.toLocaleDateString(lang === "th" ? "th-TH" : "en-GB", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---
<BaseLayout lang={lang} title={t("nav.news")}>
  <h1 class="text-2xl font-bold text-slate-800">{t("nav.news")}</h1>
  <div class="mt-6 space-y-4">
    {news.map((n) => (
      <article class="rounded-xl border border-slate-200 bg-white p-5">
        <time class="text-xs font-medium text-brand-600">{fmt(n.data.date)}</time>
        <h2 class="mt-1 text-lg font-semibold text-slate-800">{pick(lang, n.data.title_th, n.data.title_en)}</h2>
        <p class="mt-2 text-sm text-slate-600">{pick(lang, n.data.summary_th, n.data.summary_en)}</p>
      </article>
    ))}
  </div>
</BaseLayout>

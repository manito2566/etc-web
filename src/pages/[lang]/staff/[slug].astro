---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { useTranslations, localizePath, pick } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/ui";
import { site } from "../../../lib/site";

export async function getStaticPaths() {
  const staff = await getCollection("staff");
  const langs: Lang[] = ["th", "en"];
  return langs.flatMap((lang) =>
    staff.map((s) => ({ params: { lang, slug: s.id }, props: { member: s } }))
  );
}
const { member } = Astro.props;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const d = member.data;
const { Content } = await render(member);

const name = pick(lang, d.name_th, d.name_en || d.name_th);
const expertise = pick(lang, d.expertise_th, d.expertise_en)
  .split(",").map((x) => x.trim()).filter(Boolean);

// ตัดคำนำหน้าตำแหน่งวิชาการออก เพื่อใช้ค้นผลงาน
const cleanName = (d.name_th || name)
  .replace(/^((ผศ|รศ|ศ|อ|ดร|ศาสตรเมธี|ผู้ช่วยศาสตราจารย์|รองศาสตราจารย์|ศาสตราจารย์|อาจารย์)\.?\s*)+/u, "")
  .trim() || name;
const q = encodeURIComponent(`"${cleanName}"`);
const scholarSearch = `https://scholar.google.com/scholar?q=${q}`;
const thaijoSearch = `https://www.google.com/search?q=${encodeURIComponent(`"${cleanName}" site:tci-thaijo.org`)}`;

const links = [
  { url: d.website, icon: "ti-world", label: lang === "th" ? "เว็บไซต์ส่วนตัว" : "Personal site" },
  { url: d.profile, icon: "ti-id-badge-2", label: lang === "th" ? "ดูประวัติ (เว็บคณะ)" : "Faculty profile" },
  { url: d.scopus, icon: "ti-database", label: "Scopus" },
  { url: d.orcid, icon: "ti-id", label: "ORCID" },
  { url: d.email ? `mailto:${d.email}` : "", icon: "ti-mail", label: lang === "th" ? "อีเมล" : "Email" },
].filter((l) => l.url);

// ลิงก์ค้นผลงาน: ใช้โปรไฟล์ Scholar จริงถ้ามี ไม่งั้นค้นจากชื่ออัตโนมัติ
const workLinks = [
  { url: d.scholar || scholarSearch, icon: "ti-school", label: "Google Scholar", auto: !d.scholar },
  { url: thaijoSearch, icon: "ti-news", label: "ThaiJO", auto: true },
];
---
<BaseLayout lang={lang} title={name}>
  <a href={localizePath(lang, "/staff")} class="text-sm text-brand-600 hover:underline">← {t("nav.staff")}</a>

  <div class="mt-3 flex flex-col gap-5 rounded-2xl border border-slate-200 bg-white p-6 sm:flex-row sm:items-center">
    {d.photo ? (
      <img src={d.photo} alt={name} class="h-28 w-28 shrink-0 rounded-full object-cover object-top" />
    ) : (
      <span class="grid h-28 w-28 shrink-0 place-items-center rounded-full bg-brand-50 text-2xl font-bold text-brand-700">{name.slice(0, 1)}</span>
    )}
    <div class="flex-1">
      <h1 class="text-2xl font-bold text-slate-800">{name}</h1>
      <p class="mt-1 text-slate-600">{pick(lang, d.position_th, d.position_en)}</p>
      <p class="mt-0.5 text-sm text-slate-400">{pick(lang, site.name_th, site.name_en)}</p>
      {links.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {links.map((l) => (
            <a href={l.url} target={l.url.startsWith("mailto:") ? "_self" : "_blank"} rel="noopener"
               class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:border-brand-400 hover:text-brand-700">
              <i class={`ti ${l.icon}`} aria-hidden="true"></i> {l.label}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>

  {expertise.length > 0 && (
    <section class="mt-6">
      <h2 class="text-sm font-semibold text-slate-500"><i class="ti ti-bulb" aria-hidden="true"></i> {lang === "th" ? "ความเชี่ยวชาญ" : "Expertise"}</h2>
      <div class="mt-2 flex flex-wrap gap-2">
        {expertise.map((e) => (
          <span class="rounded-full bg-brand-50 px-3 py-1 text-sm text-brand-700">{e}</span>
        ))}
      </div>
    </section>
  )}

  <section class="mt-6">
    <h2 class="text-sm font-semibold text-slate-500"><i class="ti ti-article" aria-hidden="true"></i> {lang === "th" ? "ผลงานวิชาการ" : "Academic works"}</h2>
    <div class="mt-2 flex flex-wrap gap-2">
      {workLinks.map((w) => (
        <a href={w.url} target="_blank" rel="noopener"
           class="inline-flex items-center gap-1.5 rounded-md border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:border-brand-400 hover:text-brand-700">
          <i class={`ti ${w.icon}`} aria-hidden="true"></i>
          {w.auto ? (lang === "th" ? `ค้นใน ${w.label}` : `Search ${w.label}`) : w.label}
        </a>
      ))}
    </div>
    <p class="mt-1.5 text-xs text-slate-400">{lang === "th" ? "ลิงก์ค้นผลงานจากชื่ออัตโนมัติ — เพิ่มลิงก์โปรไฟล์ตัวจริงได้ผ่านระบบจัดการเนื้อหา" : "Auto-generated search by name — add the exact profile link via the CMS."}</p>
  </section>

  <article class="prose-etc mt-6 max-w-none">
    <Content />
  </article>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, localizePath, pick } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { getCriteria, getSubcriteria, subsOfCriterion, statsFor } from "../../lib/qa";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const criteria = await getCriteria();
const subs = await getSubcriteria();
const total = subs.length;
const overall = statsFor(subs);
---
<BaseLayout lang={lang} title={t("nav.home")}>
  <!-- Hero -->
  <section class="rounded-2xl bg-gradient-to-br from-brand-700 to-brand-500 px-6 py-12 text-white sm:px-10">
    <p class="text-sm font-medium uppercase tracking-wide text-brand-100">AUN-QA v4.0</p>
    <h1 class="mt-2 max-w-3xl text-3xl font-bold leading-tight sm:text-4xl">{t("site.name")}</h1>
    <p class="mt-3 max-w-2xl text-brand-50">{t("qa.subtitle")}</p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a href={localizePath(lang, "/qa")} class="rounded-lg bg-white px-5 py-2.5 font-semibold text-brand-700 hover:bg-brand-50">
        {t("home.heroCta")}
      </a>
      <a href={localizePath(lang, "/about")} class="rounded-lg border border-white/40 px-5 py-2.5 font-semibold text-white hover:bg-white/10">
        {t("home.exploreProgram")}
      </a>
    </div>
  </section>

  <!-- ตัวเลขสรุป -->
  <section class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <p class="text-3xl font-bold text-brand-700">8</p>
      <p class="mt-1 text-sm text-slate-500">{t("qa.criteria")}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <p class="text-3xl font-bold text-brand-700">{total}</p>
      <p class="mt-1 text-sm text-slate-500">{t("qa.subcriteria")}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <p class="text-3xl font-bold text-brand-700">{overall.completeness}%</p>
      <p class="mt-1 text-sm text-slate-500">{t("qa.completeness")}</p>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <p class="text-3xl font-bold text-brand-700">{overall.avgRating || "–"}</p>
      <p class="mt-1 text-sm text-slate-500">{t("qa.avgRating")}</p>
    </div>
  </section>

  <!-- การ์ด 8 เกณฑ์ -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-800">{t("qa.title")}</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {criteria.map((c) => {
        const cs = statsFor(subsOfCriterion(subs, c.id));
        return (
          <a href={localizePath(lang, `/qa/${c.data.code}`)} class="group rounded-xl border border-slate-200 bg-white p-5 transition hover:border-brand-300 hover:shadow-sm">
            <div class="flex items-center gap-3">
              <span class="grid h-9 w-9 place-items-center rounded-lg bg-brand-50 font-bold text-brand-700">{c.data.code}</span>
              <span class="text-xs text-slate-400">{cs.total} {t("qa.subcriteria")}</span>
            </div>
            <h3 class="mt-3 font-semibold text-slate-800 group-hover:text-brand-700">
              {pick(lang, c.data.title_th, c.data.title_en)}
            </h3>
            <div class="mt-3 h-1.5 w-full overflow-hidden rounded-full bg-slate-100">
              <div class="h-full bg-brand-500" style={`width:${cs.completeness}%`}></div>
            </div>
            <p class="mt-1 text-xs text-slate-400">{t("qa.completeness")}: {cs.completeness}%</p>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>

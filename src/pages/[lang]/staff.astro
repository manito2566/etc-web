---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, pick, localizePath } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const staff = (await getCollection("staff")).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
---
<BaseLayout lang={lang} title={t("nav.staff")}>
  <h1 class="text-2xl font-bold text-slate-800">{t("nav.staff")}</h1>
  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {staff.map((s) => (
      <a href={localizePath(lang, `/staff/${s.id}`)} class="group rounded-xl border border-slate-200 bg-white p-5 transition hover:border-brand-400 hover:shadow-sm">
        <div class="flex items-center gap-4">
          {s.data.photo ? (
            <img src={s.data.photo} alt={pick(lang, s.data.name_th, s.data.name_en)} class="h-16 w-16 rounded-full object-cover object-top" />
          ) : (
            <span class="grid h-16 w-16 place-items-center rounded-full bg-brand-50 text-lg font-bold text-brand-700">
              {pick(lang, s.data.name_th, s.data.name_en).slice(0, 1)}
            </span>
          )}
          <div>
            <p class="font-semibold text-slate-800 group-hover:text-brand-700">{pick(lang, s.data.name_th, s.data.name_en)}</p>
            <p class="text-sm text-slate-500">{pick(lang, s.data.position_th, s.data.position_en)}</p>
          </div>
        </div>
        {pick(lang, s.data.expertise_th, s.data.expertise_en) && (
          <p class="mt-3 line-clamp-2 text-sm text-slate-600">
            {lang === "th" ? "ความเชี่ยวชาญ" : "Expertise"}: {pick(lang, s.data.expertise_th, s.data.expertise_en)}
          </p>
        )}
        <span class="mt-3 inline-block text-sm font-medium text-brand-700">{lang === "th" ? "ดูโปรไฟล์" : "View profile"} →</span>
      </a>
    ))}
  </div>
</BaseLayout>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { useTranslations, localizePath, pick } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/ui";
import { getSubcriteria } from "../../../lib/qa";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const subs = await getSubcriteria();

// แตกหลักฐานออกเป็นแถวเดียวต่อชิ้น
const rows = subs.flatMap((s) =>
  (s.data.evidence ?? []).map((e) => ({
    code: s.data.code,
    req: pick(lang, s.data.requirement_th, s.data.requirement_en),
    title: pick(lang, e.title_th, e.title_en || e.title_th),
    link: e.link,
    date: e.date ? new Date(e.date).toISOString().slice(0, 10) : "",
  }))
);
---
<BaseLayout lang={lang} title={t("qa.evidence")}>
  <a href={localizePath(lang, "/qa")} class="text-sm text-brand-600 hover:underline">← {t("qa.backToDashboard")}</a>
  <h1 class="mt-3 text-2xl font-bold text-slate-800">{t("qa.evidence")}</h1>
  <p class="mt-1 text-sm text-slate-500">{rows.length} {lang === "th" ? "รายการ" : "items"}</p>

  <input
    id="ev-search"
    type="search"
    placeholder={lang === "th" ? "ค้นหาหลักฐาน / ตัวบ่งชี้…" : "Search evidence / sub-criterion…"}
    class="mt-4 w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm focus:border-brand-500 focus:outline-none"
  />

  <div class="mt-4 overflow-hidden rounded-xl border border-slate-200 bg-white">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500">
        <tr>
          <th class="px-4 py-3 font-medium">#</th>
          <th class="px-4 py-3 font-medium">{lang === "th" ? "หลักฐาน" : "Evidence"}</th>
          <th class="px-4 py-3 font-medium">{lang === "th" ? "ตัวบ่งชี้" : "Sub-criterion"}</th>
          <th class="px-4 py-3 font-medium">{lang === "th" ? "วันที่" : "Date"}</th>
        </tr>
      </thead>
      <tbody id="ev-body" class="divide-y divide-slate-100">
        {rows.length === 0 ? (
          <tr><td colspan="4" class="px-4 py-8 text-center text-slate-400">{t("qa.noEvidence")}</td></tr>
        ) : (
          rows.map((r) => (
            <tr class="ev-row hover:bg-slate-50" data-text={`${r.code} ${r.title} ${r.req}`.toLowerCase()}>
              <td class="px-4 py-3 font-mono text-brand-700">{r.code}</td>
              <td class="px-4 py-3">
                <a href={r.link} target="_blank" rel="noopener" class="font-medium text-brand-700 hover:underline">📎 {r.title}</a>
              </td>
              <td class="px-4 py-3 text-slate-600">{r.req}</td>
              <td class="px-4 py-3 text-slate-500">{r.date || "–"}</td>
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>
</BaseLayout>

<script>
  const input = document.getElementById("ev-search") as HTMLInputElement | null;
  input?.addEventListener("input", () => {
    const q = input.value.trim().toLowerCase();
    document.querySelectorAll<HTMLElement>(".ev-row").forEach((row) => {
      const hit = (row.dataset.text ?? "").includes(q);
      row.style.display = hit ? "" : "none";
    });
  });
</script>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { useTranslations, localizePath, pick } from "../../../i18n/utils";
import { ui, type Lang, type UIKey } from "../../../i18n/ui";
import {
  getCriteria,
  getSubcriteria,
  subsOfCriterion,
  statsFor,
  pdcaStyles,
  ratingColor,
} from "../../../lib/qa";
import { verificationLinksFor } from "../../../lib/site";

export async function getStaticPaths() {
  const criteria = await getCriteria();
  const langs: Lang[] = ["th", "en"];
  return langs.flatMap((lang) =>
    criteria.map((c) => ({ params: { lang, criterion: String(c.data.code) } }))
  );
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const code = Number(Astro.params.criterion);

const criteria = await getCriteria();
const criterion = criteria.find((c) => c.data.code === code)!;
const allSubs = await getSubcriteria();
const subs = subsOfCriterion(allSubs, criterion.id);
const cs = statsFor(subs);
---
<BaseLayout lang={lang} title={`${code}. ${pick(lang, criterion.data.title_th, criterion.data.title_en)}`}>
  <a href={localizePath(lang, "/qa")} class="text-sm text-brand-600 hover:underline">← {t("qa.backToDashboard")}</a>

  <div class="mt-3 flex items-start gap-4">
    <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-600 text-xl font-bold text-white">{code}</span>
    <div>
      <h1 class="text-2xl font-bold text-slate-800">{pick(lang, criterion.data.title_th, criterion.data.title_en)}</h1>
      <p class="mt-1 text-sm text-slate-500">
        {cs.total} {t("qa.subcriteria")} · {t("qa.completeness")} {cs.completeness}% · {t("qa.avgRating")} {cs.avgRating || "–"}
      </p>
    </div>
  </div>

  <!-- รายการตัวบ่งชี้ -->
  <div class="mt-6 space-y-4">
    {subs.map((s) => {
      const pd = pdcaStyles[s.data.pdca] ?? pdcaStyles.none;
      const evs = s.data.evidence ?? [];
      const vlinks = verificationLinksFor(s.data.code);
      return (
        <article class="rounded-xl border border-slate-200 bg-white p-5">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <div class="flex items-center gap-2">
              <span class="rounded-md bg-slate-100 px-2 py-0.5 font-mono text-sm font-semibold text-slate-700">{s.data.code}</span>
              <span class={`rounded-full px-2.5 py-0.5 text-xs font-medium ${pd.bg} ${pd.text}`}>{t(pd.key as UIKey)}</span>
            </div>
            <div class="flex items-center gap-2 text-xs text-slate-500">
              <span>{t("qa.rating")}:</span>
              <span class={`inline-block h-3 w-3 rounded-full ${ratingColor(s.data.rating)}`}></span>
              <span class="font-semibold text-slate-700">{s.data.rating || "–"}/7</span>
              <span class="text-slate-400">({t("qa.target")} {s.data.target})</span>
            </div>
          </div>

          <p class="mt-3 text-slate-800">{pick(lang, s.data.requirement_th, s.data.requirement_en)}</p>

          {pick(lang, s.data.narrative_th, s.data.narrative_en) && (
            <div class="mt-3 rounded-lg bg-slate-50 p-3 text-sm text-slate-600">
              <p class="mb-1 font-medium text-slate-500">{t("qa.narrative")}</p>
              {pick(lang, s.data.narrative_th, s.data.narrative_en)}
            </div>
          )}

          <div class="mt-3 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
            {s.data.responsible && (
              <span class="text-slate-500">{t("qa.responsible")}: <span class="font-medium text-slate-700">{s.data.responsible}</span></span>
            )}
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-slate-500">{t("qa.evidenceList")}:</span>
              {evs.length === 0 ? (
                <span class="text-slate-400">{t("qa.noEvidence")}</span>
              ) : (
                evs.map((e) => (
                  <a href={e.link} target="_blank" rel="noopener" class="rounded-md bg-brand-50 px-2 py-0.5 text-xs font-medium text-brand-700 hover:bg-brand-100">
                    📎 {pick(lang, e.title_th, e.title_en || e.title_th)}
                  </a>
                ))
              )}
            </div>
          </div>

          {vlinks.length > 0 && (
            <div class="mt-3 flex flex-wrap items-center gap-2 border-t border-slate-100 pt-3 text-sm">
              <span class="text-slate-500">{t("nav.verification")}:</span>
              {vlinks.map((v) => (
                <a href={v.url} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-emerald-50 px-2 py-0.5 text-xs font-medium text-emerald-700 hover:bg-emerald-100">
                  ✓ {lang === "th" ? v.th : v.en} ↗
                </a>
              ))}
            </div>
          )}
        </article>
      );
    })}
  </div>
</BaseLayout>

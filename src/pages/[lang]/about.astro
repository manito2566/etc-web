---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, pick } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { getEntry } from "astro:content";
import { marked } from "marked";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const about = await getEntry("pages", "about");
const title = about ? pick(lang, about.data.title_th, about.data.title_en) : t("nav.about");
const bodyMd = about ? pick(lang, about.data.body_th, about.data.body_en) : "";
const bodyHtml = bodyMd ? marked.parse(bodyMd) : "";
---
<BaseLayout lang={lang} title={title}>
  <div class="flex flex-col items-center gap-4 rounded-2xl border border-slate-200 bg-white p-6 sm:flex-row sm:items-center sm:gap-6">
    <img src="/logo.png" alt={t("site.name")} class="h-32 w-32 shrink-0 object-contain" />
    <div>
      <h1 class="text-2xl font-bold text-slate-800">{t("site.name")}</h1>
      <p class="mt-1 text-slate-500">{lang === "th" ? "คณะศึกษาศาสตร์ มหาวิทยาลัยมหาสารคาม" : "Faculty of Education, Mahasarakham University"}</p>
    </div>
  </div>
  <article class="prose-etc mt-8 max-w-none" set:html={bodyHtml}></article>
</BaseLayout>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { useTranslations, localizePath, pick } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/ui";
import { getCriteria, getSubcriteria, subsOfCriterion, statsFor } from "../../../lib/qa";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const criteria = await getCriteria();
const subs = await getSubcriteria();
const today = new Date().toLocaleDateString(lang === "th" ? "th-TH" : "en-GB");
---
<BaseLayout lang={lang} title={t("qa.sar")}>
  <div class="no-print flex items-center justify-between gap-3">
    <a href={localizePath(lang, "/qa")} class="text-sm text-brand-600 hover:underline">← {t("qa.backToDashboard")}</a>
    <button onclick="window.print()" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-700">
      🖨 {t("qa.printSar")}
    </button>
  </div>

  <!-- หัวรายงาน -->
  <header class="mt-6 border-b border-slate-200 pb-4 text-center">
    <h1 class="text-2xl font-bold text-slate-900">{t("qa.sar")}</h1>
    <p class="mt-1 text-slate-600">{t("site.name")} — AUN-QA v4.0</p>
    <p class="mt-1 text-sm text-slate-400">{today}</p>
  </header>

  {criteria.map((c) => {
    const cSubs = subsOfCriterion(subs, c.id);
    const cs = statsFor(cSubs);
    return (
      <section class="print-break mt-8">
        <h2 class="border-l-4 border-brand-600 pl-3 text-xl font-bold text-slate-900">
          {t("qa.criteria")} {c.data.code}: {pick(lang, c.data.title_th, c.data.title_en)}
        </h2>
        <p class="mt-1 pl-3 text-sm text-slate-500">
          {cs.total} {t("qa.subcriteria")} · {t("qa.avgRating")} {cs.avgRating || "–"}/7
        </p>

        <div class="mt-4 space-y-5">
          {cSubs.map((s) => (
            <div class="pl-3">
              <p class="font-semibold text-slate-800">
                {s.data.code} {pick(lang, s.data.requirement_th, s.data.requirement_en)}
                <span class="ml-2 font-normal text-slate-400">[{t("qa.rating")} {s.data.rating || "–"}/7]</span>
              </p>
              {pick(lang, s.data.narrative_th, s.data.narrative_en) ? (
                <p class="mt-1 text-sm leading-relaxed text-slate-700">{pick(lang, s.data.narrative_th, s.data.narrative_en)}</p>
              ) : (
                <p class="mt-1 text-sm italic text-slate-400">{lang === "th" ? "(ยังไม่มีผลการดำเนินงาน)" : "(no narrative yet)"}</p>
              )}
              {(s.data.evidence ?? []).length > 0 && (
                <p class="mt-1 text-xs text-slate-500">
                  {t("qa.evidenceList")}: {(s.data.evidence ?? []).map((e) => pick(lang, e.title_th, e.title_en || e.title_th)).join("; ")}
                </p>
              )}
            </div>
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>

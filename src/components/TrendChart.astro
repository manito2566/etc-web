---
// กราฟแนวโน้มคะแนนรายปี (SVG ล้วน) — แกน Y = คะแนน 1-7 ตาม AUN-QA, แกน X = ปี
// ค่า <= 0 ถือว่ายังไม่ประเมิน (ข้ามจุด)
interface Line {
  name: string;
  color: string;
  values: number[]; // ความยาวเท่ากับ years
  bold?: boolean;
}
interface Props {
  years: string[];
  lines: Line[];
  hint?: string;
}
const { years, lines, hint } = Astro.props;

const W = 720;
const H = 340;
const m = { top: 20, right: 16, bottom: 40, left: 36 };
const plotW = W - m.left - m.right;
const plotH = H - m.top - m.bottom;
const yMin = 1;
const yMax = 7;

const yToPx = (v: number) => m.top + plotH - ((v - yMin) / (yMax - yMin)) * plotH;
const xToPx = (i: number) =>
  years.length <= 1 ? m.left + plotW / 2 : m.left + (plotW * i) / (years.length - 1);

const yTicks = [1, 2, 3, 4, 5, 6, 7];
---
<div class="overflow-x-auto">
  <svg viewBox={`0 0 ${W} ${H}`} class="h-auto w-full min-w-[480px]" role="img">
    <!-- เส้นกริดแนวนอน + ป้ายแกน Y -->
    {yTicks.map((v) => (
      <g>
        <line x1={m.left} y1={yToPx(v)} x2={W - m.right} y2={yToPx(v)} stroke="#eef2f7" stroke-width="1" />
        <text x={m.left - 8} y={yToPx(v)} font-size="11" fill="#94a3b8" text-anchor="end" dominant-baseline="middle">{v}</text>
      </g>
    ))}
    <!-- ป้ายแกน X (ปี) -->
    {years.map((yr, i) => (
      <text x={xToPx(i)} y={H - m.bottom + 20} font-size="12" font-weight="600" fill="#475569" text-anchor="middle">{yr}</text>
    ))}
    <!-- เส้นข้อมูล -->
    {lines.map((ln) => {
      const pts = ln.values
        .map((v, i) => ({ v, x: xToPx(i), y: yToPx(v) }))
        .filter((p) => p.v > 0);
      const path = pts.map((p, i) => `${i === 0 ? "M" : "L"}${p.x},${p.y}`).join(" ");
      return (
        <g>
          {pts.length > 1 && (
            <path d={path} fill="none" stroke={ln.color} stroke-width={ln.bold ? 3.5 : 2} stroke-linejoin="round" stroke-linecap="round" />
          )}
          {pts.map((p) => (
            <circle cx={p.x} cy={p.y} r={ln.bold ? 4.5 : 3.5} fill={ln.color} />
          ))}
        </g>
      );
    })}
  </svg>
</div>

<!-- คำอธิบายเส้น (legend) -->
<div class="mt-3 flex flex-wrap gap-x-4 gap-y-1.5">
  {lines.map((ln) => (
    <span class="inline-flex items-center gap-1.5 text-xs text-slate-600">
      <span class="inline-block h-2.5 w-2.5 rounded-full" style={`background:${ln.color}`}></span>
      <span class={ln.bold ? "font-semibold text-slate-800" : ""}>{ln.name}</span>
    </span>
  ))}
</div>

{hint && years.length <= 1 && (
  <p class="mt-2 text-xs italic text-slate-400">{hint}</p>
)}

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { useTranslations, localizePath, pick } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/ui";

export async function getStaticPaths() {
  const courses = await getCollection("courses");
  const langs: Lang[] = ["th", "en"];
  return langs.flatMap((lang) =>
    courses.map((c) => ({ params: { lang, slug: c.id }, props: { course: c } }))
  );
}
const { course } = Astro.props;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const d = course.data;

const programLabel: Record<string, { th: string; en: string }> = {
  bachelor: { th: "ปริญญาตรี", en: "Bachelor's" },
  master: { th: "ปริญญาโท", en: "Master's" },
  doctoral: { th: "ปริญญาเอก", en: "Doctoral" },
};
const pLabel = programLabel[d.program] ?? { th: "", en: "" };
const name = pick(lang, d.name_th, d.name_en || d.name_th);
const desc = pick(lang, d.desc_th, d.desc_en);
---
<BaseLayout lang={lang} title={`${d.code} ${name}`}>
  <a href={localizePath(lang, `/programs/${d.program}`)} class="text-sm text-brand-600 hover:underline">
    ← {pick(lang, pLabel.th, pLabel.en)}
  </a>

  <div class="mt-3 rounded-2xl border border-slate-200 bg-white p-6">
    <div class="flex flex-wrap items-center gap-2">
      <span class="rounded-md bg-slate-100 px-2.5 py-1 font-mono text-sm font-semibold text-brand-700">{d.code}</span>
      <span class="rounded-full bg-gold-100 px-2.5 py-0.5 text-xs font-medium text-brand-800">{pick(lang, pLabel.th, pLabel.en)}</span>
      {d.category_th && (
        <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">{pick(lang, d.category_th, d.category_en)}</span>
      )}
      {d.credits && <span class="text-xs text-slate-400">{d.credits} {lang === "th" ? "หน่วยกิต" : "credits"}</span>}
    </div>

    <h1 class="mt-3 text-2xl font-bold text-slate-800">{pick(lang, d.name_th, d.name_en || d.name_th)}</h1>
    {lang === "th" && d.name_en && <p class="mt-1 text-slate-500">{d.name_en}</p>}

    {desc ? (
      <p class="mt-5 leading-relaxed text-slate-700">{desc}</p>
    ) : (
      <p class="mt-5 text-sm italic text-slate-400">{lang === "th" ? "ยังไม่มีคำอธิบายรายวิชา" : "No course description yet."}</p>
    )}
  </div>
</BaseLayout>

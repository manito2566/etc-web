---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, pick, localizePath } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const news = (await getCollection("news")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const fmt = (d: Date) =>
  d.toLocaleDateString(lang === "th" ? "th-TH" : "en-GB", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---
<BaseLayout lang={lang} title={t("nav.news")}>
  <h1 class="text-2xl font-bold text-slate-800">{t("nav.news")}</h1>
  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {news.map((n) => (
      <a href={localizePath(lang, `/news/${n.id}`)} class="group flex flex-col overflow-hidden rounded-xl border border-slate-200 bg-white transition hover:border-brand-400 hover:shadow-sm">
        {n.data.cover ? (
          <img src={n.data.cover} alt={pick(lang, n.data.title_th, n.data.title_en)} class="h-44 w-full object-cover" />
        ) : (
          <div class="flex h-44 w-full items-center justify-center bg-brand-50 text-brand-300">
            <i class="ti ti-news text-5xl" aria-hidden="true"></i>
          </div>
        )}
        <div class="flex flex-1 flex-col p-5">
          <time class="text-xs font-medium text-brand-600">{fmt(n.data.date)}</time>
          <h2 class="mt-1 font-semibold text-slate-800 group-hover:text-brand-700">{pick(lang, n.data.title_th, n.data.title_en)}</h2>
          <p class="mt-2 flex-1 text-sm text-slate-600">{pick(lang, n.data.summary_th, n.data.summary_en)}</p>
          <span class="mt-3 text-sm font-medium text-brand-700">{t("common.readMore")} →</span>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { site, ecosystem } from "../../lib/site";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

// ช่องทางตามกลุ่มผู้ใช้ (ปรับลิงก์/อีเมลจริงได้ภายหลังผ่าน CMS หรือไฟล์นี้)
const channels = lang === "th"
  ? [
      { icon: "ti-user", title: "นิสิต / ผู้ปกครอง", desc: "สอบถามการเรียน การสมัคร และทุนการศึกษา" },
      { icon: "ti-briefcase", title: "ผู้ใช้บัณฑิต", desc: "ความร่วมมือ ฝึกงาน และรับนิสิตเข้าทำงาน" },
      { icon: "ti-users", title: "ศิษย์เก่า", desc: "เครือข่ายศิษย์เก่า กิจกรรม และความร่วมมือ", link: ecosystem.find((e) => e.key === "alumni")!.url },
    ]
  : [
      { icon: "ti-user", title: "Students / parents", desc: "Admissions, study and scholarship enquiries" },
      { icon: "ti-briefcase", title: "Employers", desc: "Collaboration, internships and recruitment" },
      { icon: "ti-users", title: "Alumni", desc: "Alumni network, events and collaboration", link: ecosystem.find((e) => e.key === "alumni")!.url },
    ];
---
<BaseLayout lang={lang} title={t("contact.title")}>
  <h1 class="text-2xl font-bold text-slate-800">{t("contact.title")}</h1>

  <div class="mt-4 rounded-xl border border-slate-200 bg-white p-6">
    <p class="font-semibold text-slate-800">{lang === "th" ? site.name_th : site.name_en}</p>
    <p class="mt-1 text-sm text-slate-600"><i class="ti ti-building text-brand-600" aria-hidden="true"></i> {lang === "th" ? site.faculty_th : site.faculty_en}</p>
    <p class="mt-1 text-sm text-slate-600"><i class="ti ti-mail text-brand-600" aria-hidden="true"></i> edu@msu.ac.th</p>
    <p class="mt-1 text-sm text-slate-400">{lang === "th" ? "(แก้ไขอีเมล/เบอร์โทรจริงได้ผ่านระบบจัดการเนื้อหา)" : "(Update real email/phone via the CMS)"}</p>
  </div>

  <div class="mt-6 grid gap-4 sm:grid-cols-3">
    {channels.map((c) => (
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <i class={`ti ${c.icon} text-2xl text-brand-600`} aria-hidden="true"></i>
        <h2 class="mt-2 font-semibold text-slate-800">{c.title}</h2>
        <p class="mt-1 text-sm text-slate-600">{c.desc}</p>
        {c.link && (
          <a href={c.link} target="_blank" rel="noopener" class="mt-2 inline-block text-sm font-medium text-brand-700 hover:underline">
            {t("common.open")} <i class="ti ti-external-link text-xs" aria-hidden="true"></i>
          </a>
        )}
      </div>
    ))}
  </div>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, localizePath, pick } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const projects = (await getCollection("projects")).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
const truncate = (s: string, n = 100) => s.length > n ? s.slice(0, n).trimEnd() + "…" : s;
---
<BaseLayout lang={lang} title={t("projects.title")} description={t("projects.desc")}>
  <h1 class="text-2xl font-bold text-slate-800">{t("projects.title")}</h1>
  <p class="mt-1 text-slate-500">{t("projects.desc")}</p>
  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {projects.map((p) => {
      const desc = pick(lang, p.data.desc_th, p.data.desc_en);
      return (
        <a
          href={localizePath(lang, `/projects/${p.id}`)}
          class="group flex flex-col overflow-hidden rounded-xl border border-slate-200 bg-white transition hover:border-brand-400 hover:shadow-sm"
        >
          {p.data.cover ? (
            <img src={p.data.cover} alt={pick(lang, p.data.title_th, p.data.title_en)} class="h-40 w-full object-cover" />
          ) : (
            <div class="flex h-40 items-center justify-center bg-brand-50 text-brand-600">
              <i class={`ti ti-${p.data.icon} text-5xl`} aria-hidden="true"></i>
            </div>
          )}
          <div class="flex flex-1 flex-col p-5">
            <div class="flex items-center justify-between">
              <span class="text-xs font-medium text-brand-700">{pick(lang, p.data.category_th, p.data.category_en)}</span>
              {p.data.year && <span class="text-xs text-slate-400">{p.data.year}</span>}
            </div>
            <h2 class="mt-1 font-semibold text-slate-800 group-hover:text-brand-700">{pick(lang, p.data.title_th, p.data.title_en)}</h2>
            {desc && <p class="mt-2 flex-1 text-sm text-slate-600">{truncate(desc)}</p>}
            <div class="mt-3 flex flex-wrap items-center gap-2">
              {p.data.student && <span class="text-xs text-slate-500"><i class="ti ti-user" aria-hidden="true"></i> {p.data.student}</span>}
              {pick(lang, p.data.award_th, p.data.award_en) && (
                <span class="rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-800"><i class="ti ti-trophy" aria-hidden="true"></i> {pick(lang, p.data.award_th, p.data.award_en)}</span>
              )}
            </div>
          </div>
        </a>
      );
    })}
  </div>
</BaseLayout>

---
import { useTranslations } from "../i18n/utils";
import type { Lang } from "../i18n/ui";
interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---
<footer class="no-print mt-16 border-t-2 border-gold-400 bg-brand-900 text-brand-100">
  <div class="mx-auto max-w-6xl px-4 py-8 text-sm">
    <div class="flex items-center gap-2">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-gold-400 text-sm font-bold text-brand-900">ETC</span>
      <p class="font-semibold text-white">{t("site.name")}</p>
    </div>
    <p class="mt-2 text-brand-200">{t("site.tagline")}</p>
    <p class="mt-4 text-brand-300">© {year} {t("site.name")} — {t("footer.rights")}</p>
  </div>
</footer>

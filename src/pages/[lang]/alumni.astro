---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { ecosystem } from "../../lib/site";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const alumniUrl = ecosystem.find((e) => e.key === "alumni")!.url;
const points = lang === "th"
  ? ["ทำเนียบศิษย์เก่า ค้นหาเพื่อนร่วมรุ่นตามปีที่จบ", "กิจกรรมคืนสู่เหย้าและสัมมนากว่า 50 ครั้งต่อปี", "ข่าวสารและเรื่องราวความสำเร็จของศิษย์เก่า"]
  : ["Alumni directory — find classmates by graduation year", "50+ homecoming and seminar activities per year", "News and alumni success stories"];
---
<BaseLayout lang={lang} title={t("alumni.title")} description={t("alumni.desc")}>
  <section class="overflow-hidden rounded-2xl bg-gradient-to-br from-brand-700 to-brand-500 px-6 py-12 text-white sm:px-10">
    <h1 class="text-3xl font-bold">{t("alumni.title")}</h1>
    <p class="mt-3 max-w-2xl text-brand-50">{t("alumni.desc")}</p>
    <a href={alumniUrl} target="_blank" rel="noopener" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-white px-5 py-2.5 font-semibold text-brand-800 hover:bg-brand-50">
      {t("alumni.openApp")} <i class="ti ti-external-link" aria-hidden="true"></i>
    </a>
  </section>

  <section class="mt-8 grid gap-4 sm:grid-cols-3">
    {points.map((p) => (
      <div class="rounded-xl border border-slate-200 bg-white p-5 text-slate-700">
        <i class="ti ti-check text-xl text-brand-600" aria-hidden="true"></i>
        <p class="mt-2 text-sm">{p}</p>
      </div>
    ))}
  </section>
</BaseLayout>

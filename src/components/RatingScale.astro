---
// ตารางเกณฑ์คะแนน AUN-QA 7 ระดับ (ข้อมูลอ้างอิง)
import { useTranslations, pick } from "../i18n/utils";
import type { Lang } from "../i18n/ui";
import { ratingScale, ratingHex } from "../lib/qa";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
  <table class="w-full text-left text-sm">
    <thead class="bg-slate-50 text-slate-500">
      <tr>
        <th class="px-4 py-3 text-center font-medium">{t("qa.scaleLevel")}</th>
        <th class="px-4 py-3 font-medium">{t("qa.scaleName")}</th>
        <th class="px-4 py-3 font-medium">{t("qa.scaleDesc")}</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      {ratingScale.map((r) => (
        <tr class="align-top">
          <td class="px-4 py-3 text-center">
            <span
              class="inline-grid h-7 w-7 place-items-center rounded-full text-sm font-bold text-white"
              style={`background:${ratingHex(r.level)}`}
            >{r.level}</span>
          </td>
          <td class="px-4 py-3 font-semibold text-slate-800">{pick(lang, r.name_th, r.name_en)}</td>
          <td class="px-4 py-3 text-slate-600">{pick(lang, r.desc_th, r.desc_en)}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

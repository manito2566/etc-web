---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, localizePath, pick } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { getCollection } from "astro:content";
import { ecosystem, verificationUrl } from "../../lib/site";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const programs = (await getCollection("programs")).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
const projects = (await getCollection("projects")).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
const news = (await getCollection("news"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
const fmt = (d: Date) =>
  d.toLocaleDateString(lang === "th" ? "th-TH" : "en-GB", { year: "numeric", month: "short", day: "numeric" });

const stats = [
  { label: t("stat.alumni"), value: "1,000+" },
  { label: t("stat.events"), value: "50+" },
  { label: t("stat.staff"), value: "10" },
  { label: t("stat.quality"), value: "2 → 3" },
];
const audiences = [
  t("audience.student"), t("audience.parent"), t("audience.staff"),
  t("audience.alumni"), t("audience.employer"),
];
---
<BaseLayout lang={lang} title={t("nav.home")} description={t("site.tagline")}>
  <!-- Hero -->
  <section class="overflow-hidden rounded-2xl bg-gradient-to-br from-brand-700 to-brand-500 px-6 py-12 text-white sm:px-10">
    <span class="inline-block rounded-full bg-gold-400 px-3 py-1 text-sm font-medium text-brand-900">{t("home.badge")}</span>
    <h1 class="mt-3 max-w-3xl text-3xl font-bold leading-snug text-gold-300 sm:text-4xl">{t("site.name")}</h1>
    <p class="mt-3 max-w-2xl text-brand-50">{t("home.heroDesc")}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {programs.map((p) => (
        <span class="rounded-full bg-white/15 px-3 py-1 text-sm text-white">
          <i class={`ti ti-${p.data.icon}`} aria-hidden="true"></i> {pick(lang, p.data.level_th, p.data.level_en)}
        </span>
      ))}
    </div>
    <div class="mt-6 flex flex-wrap gap-3">
      <a href={localizePath(lang, "/courses")} class="rounded-lg bg-white px-5 py-2.5 font-semibold text-brand-800 hover:bg-brand-50">{t("home.applyCta")}</a>
      <a href={localizePath(lang, "/about")} class="rounded-lg border border-white/50 px-5 py-2.5 font-semibold text-white hover:bg-white/10">{t("home.exploreProgram")}</a>
    </div>
  </section>

  <!-- ตัวเลขสำคัญ -->
  <section class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-4">
    {stats.map((s) => (
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-2xl font-bold text-brand-700">{s.value}</p>
        <p class="mt-1 text-sm text-slate-500">{s.label}</p>
      </div>
    ))}
  </section>

  <!-- ไฮไลต์คุณภาพ (เชื่อมระบบทวนสอบ) -->
  <a href={verificationUrl} target="_blank" rel="noopener" class="group mt-6 flex items-start justify-between gap-4 rounded-xl border border-emerald-200 bg-emerald-50 p-5 transition hover:border-emerald-400">
    <div class="flex items-start gap-3">
      <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-emerald-600 text-white"><i class="ti ti-trending-up text-xl" aria-hidden="true"></i></span>
      <div>
        <p class="font-semibold text-emerald-800 group-hover:text-emerald-900">{t("quality.title")}</p>
        <p class="mt-0.5 text-sm text-slate-600">{t("quality.desc")}</p>
        <p class="mt-1 text-sm font-medium text-emerald-700">{t("quality.link")} <i class="ti ti-external-link text-xs" aria-hidden="true"></i></p>
      </div>
    </div>
  </a>

  <!-- ผลงานนิสิตเด่น -->
  <section class="mt-10">
    <div class="flex items-center justify-between">
      <h2 class="text-xl font-bold text-slate-800">{t("home.studentWork")}</h2>
      <a href={localizePath(lang, "/projects")} class="text-sm font-medium text-brand-700 hover:underline">{t("common.viewAll")} →</a>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => (
        <a href={localizePath(lang, "/projects")} class="group overflow-hidden rounded-xl border border-slate-200 bg-white transition hover:border-brand-300">
          <div class="flex h-28 items-center justify-center bg-brand-50 text-brand-600">
            <i class={`ti ti-${p.data.icon} text-4xl`} aria-hidden="true"></i>
          </div>
          <div class="p-4">
            <span class="text-xs font-medium text-brand-700">{pick(lang, p.data.category_th, p.data.category_en)}</span>
            <h3 class="mt-1 font-semibold text-slate-800 group-hover:text-brand-700">{pick(lang, p.data.title_th, p.data.title_en)}</h3>
            {pick(lang, p.data.award_th, p.data.award_en) && (
              <span class="mt-2 inline-block rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-800"><i class="ti ti-trophy" aria-hidden="true"></i> {pick(lang, p.data.award_th, p.data.award_en)}</span>
            )}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ระบบนิเวศของสาขา -->
  <section class="mt-10">
    <h2 class="text-xl font-bold text-slate-800">{t("home.ecosystemTitle")}</h2>
    <p class="mt-1 text-sm text-slate-500">{t("home.ecosystemDesc")}</p>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      {ecosystem.map((e) => (
        <a href={e.url} target="_blank" rel="noopener" class="group rounded-xl border border-slate-200 bg-white p-5 transition hover:border-brand-400">
          <i class={`ti ${e.icon} text-2xl text-brand-600`} aria-hidden="true"></i>
          <p class="mt-3 font-semibold text-slate-800 group-hover:text-brand-700">
            {pick(lang, e.title_th, e.title_en)} <i class="ti ti-external-link text-xs text-slate-400" aria-hidden="true"></i>
          </p>
          <p class="mt-1 text-sm text-slate-500">{pick(lang, e.desc_th, e.desc_en)}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- ข่าว/กิจกรรม -->
  {news.length > 0 && (
    <section class="mt-10">
      <div class="flex items-center justify-between">
        <h2 class="text-xl font-bold text-slate-800">{t("home.newsTitle")}</h2>
        <a href={localizePath(lang, "/news")} class="text-sm font-medium text-brand-700 hover:underline">{t("common.viewAll")} →</a>
      </div>
      <div class="mt-4 grid gap-4 sm:grid-cols-3">
        {news.map((n) => (
          <article class="rounded-xl border border-slate-200 bg-white p-5">
            <time class="text-xs font-medium text-brand-600">{fmt(n.data.date)}</time>
            <h3 class="mt-1 font-semibold text-slate-800">{pick(lang, n.data.title_th, n.data.title_en)}</h3>
            <p class="mt-2 text-sm text-slate-600">{pick(lang, n.data.summary_th, n.data.summary_en)}</p>
          </article>
        ))}
      </div>
    </section>
  )}

  <!-- ติดต่อสำหรับทุกกลุ่ม -->
  <section class="mt-10 rounded-xl border border-slate-200 bg-white p-6">
    <h2 class="text-lg font-bold text-slate-800">{t("home.contactTitle")}</h2>
    <div class="mt-3 flex flex-wrap gap-2">
      {audiences.map((a) => (
        <span class="rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-600">{a}</span>
      ))}
    </div>
    <a href={localizePath(lang, "/contact")} class="mt-4 inline-block rounded-lg bg-brand-600 px-5 py-2 text-sm font-semibold text-white hover:bg-brand-700">{t("contact.title")} →</a>
  </section>
</BaseLayout>

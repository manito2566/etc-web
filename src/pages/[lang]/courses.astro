---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, pick, localizePath } from "../../i18n/utils";
import type { Lang } from "../../i18n/ui";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const programs = (await getCollection("programs")).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0)
);
const courseCount = (await getCollection("courses")).length;
---
<BaseLayout lang={lang} title={t("courses.title")} description={t("courses.desc")}>
  <h1 class="text-2xl font-bold text-slate-800">{t("courses.title")}</h1>
  <p class="mt-1 text-slate-500">{t("courses.desc")}</p>

  <!-- 3 ระดับการศึกษา -->
  <div class="mt-6 grid gap-4 md:grid-cols-3">
    {programs.map((p) => (
      <article class="flex flex-col rounded-xl border border-slate-200 bg-white p-5">
        <div class="flex items-center gap-3">
          <span class="grid h-11 w-11 place-items-center rounded-lg bg-brand-50 text-brand-600">
            <i class={`ti ti-${p.data.icon} text-2xl`} aria-hidden="true"></i>
          </span>
          <div>
            <span class="rounded-full bg-gold-100 px-2 py-0.5 text-xs font-medium text-brand-800">{pick(lang, p.data.level_th, p.data.level_en)}</span>
            <p class="mt-0.5 text-xs text-slate-400">{pick(lang, p.data.degree_th, p.data.degree_en)} · {pick(lang, p.data.duration_th, p.data.duration_en)}</p>
          </div>
        </div>
        <h2 class="mt-3 font-semibold text-slate-800">{pick(lang, p.data.name_th, p.data.name_en)}</h2>
        <p class="mt-2 flex-1 text-sm text-slate-600">{pick(lang, p.data.desc_th, p.data.desc_en)}</p>
        <a href={localizePath(lang, `/programs/${p.id}`)} class="mt-3 text-sm font-medium text-brand-700 hover:underline">
          {t("common.readMore")} →
        </a>
      </article>
    ))}
  </div>

  <p class="mt-6 text-sm text-slate-400">{lang === "th" ? "คลิกแต่ละหลักสูตรเพื่อดูรายละเอียดและรายวิชา" : "Click a programme to view details and courses."}</p>
</BaseLayout>

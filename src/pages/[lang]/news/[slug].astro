---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { useTranslations, localizePath, pick } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/ui";
import { marked } from "marked";

export async function getStaticPaths() {
  const news = await getCollection("news");
  const langs: Lang[] = ["th", "en"];
  return langs.flatMap((lang) =>
    news.map((n) => ({ params: { lang, slug: n.id }, props: { item: n } }))
  );
}
const { item } = Astro.props;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const d = item.data;
const title = pick(lang, d.title_th, d.title_en || d.title_th);
const bodyMd = pick(lang, d.body_th, d.body_en);
const bodyHtml = bodyMd ? marked.parse(bodyMd) : "";
const fmt = d.date.toLocaleDateString(lang === "th" ? "th-TH" : "en-GB", {
  year: "numeric", month: "long", day: "numeric",
});
---
<BaseLayout lang={lang} title={title} description={pick(lang, d.summary_th, d.summary_en)}>
  <a href={localizePath(lang, "/news")} class="text-sm text-brand-600 hover:underline">← {t("nav.news")}</a>

  <article class="mt-3">
    <time class="text-sm font-medium text-brand-600">{fmt}</time>
    <h1 class="mt-1 text-2xl font-bold text-slate-800">{title}</h1>
    {pick(lang, d.summary_th, d.summary_en) && (
      <p class="mt-2 text-lg text-slate-600">{pick(lang, d.summary_th, d.summary_en)}</p>
    )}
    {d.cover && (
      <img src={d.cover} alt={title} class="mt-5 w-full rounded-xl border border-slate-200 object-cover" />
    )}
    {bodyHtml && <div class="prose-etc mt-6 max-w-none" set:html={bodyHtml}></div>}
  </article>
</BaseLayout>

---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import RadarChart from "../../../components/RadarChart.astro";
import TrendChart from "../../../components/TrendChart.astro";
import RatingScale from "../../../components/RatingScale.astro";
import { useTranslations, localizePath, pick } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/ui";
import {
  getCriteria,
  getSubcriteria,
  subsOfCriterion,
  statsFor,
  getAssessments,
  overallOf,
  scoreOf,
} from "../../../lib/qa";
import { site } from "../../../lib/site";

export function getStaticPaths() {
  return [{ params: { lang: "th" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

const criteria = await getCriteria();
const subs = await getSubcriteria();
const overall = statsFor(subs);

const rows = criteria.map((c) => {
  const cs = statsFor(subsOfCriterion(subs, c.id));
  return { c, cs };
});
const radarLabels = criteria.map((c) => String(c.data.code));
const radarValues = rows.map((r) => r.cs.avgRating);

// ---- ข้อมูลกราฟแนวโน้มคะแนนรายปี ----
const assessments = await getAssessments();
const years = assessments.map((a) => a.data.label || String(a.data.year));
const palette = ["#2563eb", "#0891b2", "#7c3aed", "#db2777", "#ea580c", "#16a34a", "#ca8a04", "#0d9488"];
const trendLines = [
  // เส้นคะแนนรวม (เด่น)
  { name: t("qa.trendOverall"), color: "#0f172a", bold: true, values: assessments.map((a) => overallOf(a)) },
  // เส้นรายเกณฑ์ C1-C8
  ...criteria.map((c, i) => ({
    name: `${t("qa.criteria")} ${c.data.code}`,
    color: palette[i % palette.length],
    values: assessments.map((a) => scoreOf(a, c.data.code)),
  })),
];
---
<BaseLayout lang={lang} title={t("qa.dashboard")} description={t("qa.subtitle")}>
  <div class="flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold text-slate-800">{t("qa.title")}</h1>
      <p class="mt-1 text-slate-500">{t("qa.subtitle")}</p>
    </div>
    <div class="flex gap-2">
      <a href={site.verificationUrl} target="_blank" rel="noopener" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100">{t("nav.verification")} ↗</a>
      <a href={localizePath(lang, "/qa/evidence")} class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100">{t("qa.evidence")}</a>
      <a href={localizePath(lang, "/qa/sar")} class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-700">{t("qa.sar")}</a>
    </div>
  </div>

  <!-- ภาพรวม: ตัวเลข + เรดาร์ -->
  <section class="mt-6 grid gap-6 lg:grid-cols-3">
    <div class="grid grid-cols-2 gap-4 lg:col-span-2 lg:grid-cols-2">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm text-slate-500">{t("qa.totalSub")}</p>
        <p class="mt-1 text-3xl font-bold text-brand-700">{overall.total}</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm text-slate-500">{t("qa.completeness")}</p>
        <p class="mt-1 text-3xl font-bold text-brand-700">{overall.completeness}%</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm text-slate-500">{t("qa.avgRating")}</p>
        <p class="mt-1 text-3xl font-bold text-brand-700">{overall.avgRating || "–"}</p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <p class="text-sm text-slate-500">{lang === "th" ? "ประเมินแล้ว" : "Rated"}</p>
        <p class="mt-1 text-3xl font-bold text-brand-700">{overall.rated}/{overall.total}</p>
      </div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <p class="text-center text-sm font-medium text-slate-500">{t("qa.avgRating")} ({lang === "th" ? "รายเกณฑ์" : "by criterion"})</p>
      <RadarChart labels={radarLabels} values={radarValues} max={7} />
    </div>
  </section>

  <!-- การ์ดเชื่อมระบบทวนสอบ + ดีปลิงก์โมดูล -->
  <section class="mt-8 rounded-xl border border-emerald-200 bg-emerald-50 p-5">
    <div class="flex items-start justify-between gap-4">
      <div class="flex items-start gap-3">
        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-emerald-600 text-white">✓</span>
        <div>
          <a href={site.verificationUrl} target="_blank" rel="noopener" class="font-semibold text-emerald-800 hover:text-emerald-900">{t("qa.verification")} ↗</a>
          <p class="mt-0.5 text-sm text-slate-600">{t("qa.verificationDesc")}</p>
        </div>
      </div>
    </div>
    <div class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
      {Object.values(site.verification).map((v) => (
        <a href={v.url} target="_blank" rel="noopener" class="flex items-center justify-between rounded-lg border border-emerald-200 bg-white px-3 py-2 text-sm font-medium text-emerald-700 hover:border-emerald-400">
          <span>{lang === "th" ? v.th : v.en}</span>
          <span class="text-emerald-400">↗</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ตาราง 8 เกณฑ์ -->
  <section class="mt-8 overflow-hidden rounded-xl border border-slate-200 bg-white">
    <table class="w-full text-left text-sm">
      <thead class="bg-slate-50 text-slate-500">
        <tr>
          <th class="px-4 py-3 font-medium">#</th>
          <th class="px-4 py-3 font-medium">{t("qa.criteria")}</th>
          <th class="px-4 py-3 text-center font-medium">{t("qa.subcriteria")}</th>
          <th class="px-4 py-3 font-medium">{t("qa.completeness")}</th>
          <th class="px-4 py-3 text-center font-medium">{t("qa.avgRating")}</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        {rows.map(({ c, cs }) => (
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3">
              <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-50 font-bold text-brand-700">{c.data.code}</span>
            </td>
            <td class="px-4 py-3">
              <a href={localizePath(lang, `/qa/${c.data.code}`)} class="font-medium text-slate-800 hover:text-brand-700">
                {pick(lang, c.data.title_th, c.data.title_en)}
              </a>
            </td>
            <td class="px-4 py-3 text-center text-slate-600">{cs.total}</td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <div class="h-1.5 w-24 overflow-hidden rounded-full bg-slate-100">
                  <div class="h-full bg-brand-500" style={`width:${cs.completeness}%`}></div>
                </div>
                <span class="text-xs text-slate-500">{cs.completeness}%</span>
              </div>
            </td>
            <td class="px-4 py-3 text-center font-semibold text-slate-700">{cs.avgRating || "–"}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <!-- กราฟแนวโน้มคะแนนรายปี -->
  <section class="mt-8 rounded-xl border border-slate-200 bg-white p-5">
    <div class="flex flex-wrap items-end justify-between gap-2">
      <h2 class="text-lg font-bold text-slate-800">{t("qa.trend")}</h2>
      <span class="text-xs text-slate-400">{t("qa.year")} · {t("qa.score")} 1–7</span>
    </div>
    <div class="mt-4">
      <TrendChart years={years} lines={trendLines} hint={t("qa.oneYearHint")} />
    </div>
  </section>

  <!-- ตารางเกณฑ์คะแนน AUN-QA 7 ระดับ -->
  <section class="mt-8">
    <h2 class="text-lg font-bold text-slate-800">{t("qa.scaleTitle")}</h2>
    <div class="mt-4">
      <RatingScale lang={lang} />
    </div>
  </section>
</BaseLayout>

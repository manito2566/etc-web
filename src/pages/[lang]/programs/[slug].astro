---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { useTranslations, localizePath, pick } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/ui";

export async function getStaticPaths() {
  const programs = await getCollection("programs");
  const langs: Lang[] = ["th", "en"];
  return langs.flatMap((lang) =>
    programs.map((p) => ({ params: { lang, slug: p.id }, props: { program: p } }))
  );
}
const { program } = Astro.props;
const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const d = program.data;
const { Content } = await render(program);

// รายวิชาของหลักสูตรนี้ จัดกลุ่มตามหมวดวิชา (เรียงตาม order)
const allCourses = (await getCollection("courses"))
  .filter((c) => c.data.program === program.id)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const courseGroups: { category: string; items: typeof allCourses }[] = [];
for (const c of allCourses) {
  const cat = pick(lang, c.data.category_th, c.data.category_en) || (lang === "th" ? "รายวิชา" : "Courses");
  let g = courseGroups.find((x) => x.category === cat);
  if (!g) { g = { category: cat, items: [] }; courseGroups.push(g); }
  g.items.push(c);
}
---
<BaseLayout lang={lang} title={pick(lang, d.name_th, d.name_en)} description={pick(lang, d.desc_th, d.desc_en)}>
  <a href={localizePath(lang, "/courses")} class="text-sm text-brand-600 hover:underline">← {t("courses.title")}</a>

  <div class="mt-3 flex items-start gap-4">
    <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-brand-600 text-white">
      <i class={`ti ti-${d.icon} text-2xl`} aria-hidden="true"></i>
    </span>
    <div>
      <div class="flex flex-wrap items-center gap-2">
        <span class="rounded-full bg-gold-100 px-2.5 py-0.5 text-xs font-medium text-brand-800">{pick(lang, d.level_th, d.level_en)}</span>
        <span class="text-xs text-slate-400">{pick(lang, d.degree_th, d.degree_en)} · {pick(lang, d.duration_th, d.duration_en)}</span>
      </div>
      <h1 class="mt-1 text-2xl font-bold text-slate-800">{pick(lang, d.name_th, d.name_en)}</h1>
    </div>
  </div>

  <p class="mt-4 rounded-xl border border-slate-200 bg-white p-4 text-slate-700">{pick(lang, d.desc_th, d.desc_en)}</p>

  <article class="prose-etc mt-6 max-w-none">
    <Content />
  </article>

  {courseGroups.length > 0 && (
    <section class="mt-8">
      <h2 class="border-l-4 border-gold-400 pl-3 text-lg font-bold text-slate-800">{lang === "th" ? "รายวิชาหลัก" : "Key courses"}</h2>
      <div class="mt-4 space-y-6">
        {courseGroups.map((g) => (
          <div>
            <h3 class="mb-2 font-semibold text-brand-700">{g.category}</h3>
            <div class="overflow-hidden rounded-xl border border-slate-200 bg-white">
              <table class="w-full text-left text-sm">
                <tbody class="divide-y divide-slate-100">
                  {g.items.map((c) => (
                    <tr class="align-top hover:bg-slate-50">
                      <td class="w-24 px-4 py-3 font-mono text-brand-700">{c.data.code}</td>
                      <td class="px-4 py-3">
                        <p class="font-medium text-slate-800">{pick(lang, c.data.name_th, c.data.name_en)}</p>
                        {pick(lang, c.data.desc_th, c.data.desc_en) && (
                          <p class="mt-0.5 text-xs text-slate-500">{pick(lang, c.data.desc_th, c.data.desc_en)}</p>
                        )}
                      </td>
                      <td class="w-20 whitespace-nowrap px-4 py-3 text-right text-slate-600">{c.data.credits}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
